                                          "type": "text",
                                          "id": "K14BE",
                                          "name": "P",
                                          "fill": "$foreground",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "OpsBoard is operated by OpsBoard Labs. We built this product to be private by default — your missions, tasks, notes, and voice captures belong to you. We never sell your data, and we never use the contents of your tasks or recordings to train advertising models.",
                                          "lineHeight": 1.65,
                                          "fontFamily": "DM Sans",
                                          "fontSize": 16,
                                          "fontWeight": "normal"
                                        },
                                        {
                                          "type": "text",
                                          "id": "tV8rK",
                                          "name": "P",
                                          "fill": "$foreground",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "This policy applies to the OpsBoard mobile and desktop apps and to opsboard.app. By using OpsBoard you agree to the practices described below.",
