                                          "fill": "$foreground",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "Voice capture only runs while you are actively holding the record control. OpsBoard never listens in the background, and no audio leaves your device until you release the button.",
                                          "lineHeight": 1.65,
                                          "fontFamily": "DM Sans",
                                          "fontSize": 16,
                                          "fontWeight": "normal"
                                        },
