                                          "fill": "$foreground",
                                          "textGrowth": "fixed-width",
                                          "width": "fill_container",
                                          "content": "The tasks, missions, categories, notes, due dates, and dependency links you create are stored so the board works across your devices. This content is encrypted in transit and at rest.",
