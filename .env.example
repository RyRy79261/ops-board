# OpsBoard — example environment variables.
# Copy to .env.local in apps/web and fill in. Single-user app.
# (Keep this file and turbo.json globalEnv in sync — every var lives in both.)

# --- Database (Neon Postgres) ---
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# --- AI providers ---
# Anthropic: Claude Haiku 4.5 for voice-intent classification, Opus for heavy work.
ANTHROPIC_API_KEY=
# Groq: pinned whisper-large-v3-turbo for voice transcription.
GROQ_API_KEY=

# --- App session (thin single-user auth) ---
# Shared-secret/session secret for the dashboard. Generate with: openssl rand -base64 32
OPSBOARD_SESSION_SECRET=

# --- MCP server (Claude.ai connector) ---
# Public origin used to build OAuth metadata + redirects. NEVER derive from VERCEL_URL.
# e.g. https://opsboard.example.com
MCP_PUBLIC_URL=

# --- Cron ---
# Bearer secret for /api/cron/* endpoints (e.g. closing-window reminders).
# Generate with: openssl rand -hex 32
CRON_SECRET=
