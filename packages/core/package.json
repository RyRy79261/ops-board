{
  "name": "@opsboard/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:tz:sa": "TZ=Africa/Johannesburg vitest run",
    "test:tz:de": "TZ=Europe/Berlin vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@opsboard/types": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@opsboard/eslint-config": "workspace:*",
    "@opsboard/typescript-config": "workspace:*",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.4.0",
    "fast-check": "^3.23.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
