{
  "name": "@opsboard/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./account": "./src/account.ts",
    "./api-keys": "./src/api-keys.ts",
    "./preferences": "./src/preferences.ts",
    "./testing": "./src/__tests__/db-harness.ts",
